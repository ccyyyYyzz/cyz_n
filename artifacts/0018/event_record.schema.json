          },
          "type": "array"
        },
        "representation": {
          "enum": [
            "singleton",
            "finite",
            "implicit"
          ]
        },
        "unordered": {
          "const": true
        }
      },
      "required": [
        "representation",
        "complete",
        "unordered",
        "cardinality",
        "members",
        "implicit_set"
      ],
      "type": "object"
    },
