  "$id": "https://github.com/ccyyyYyzz/cyz_n/raw/main/artifacts/0018/event_record.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "primary_outcome": {
            "const": "source_invalid"
          }
        }
      },
      "then": {
        "properties": {
          "entry_cluster": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_outcome": {
            "const": "torus_branch_ambiguous"
          }
        }
      },
      "then": {
        "properties": {
          "certificates": {
            "properties": {
              "torus_log": {
                "$ref": "#/$defs/torusCertificate"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_outcome": {
            "const": "ambiguous_tie"
          }
        }
      },
      "then": {
        "properties": {
          "certificates": {
            "properties": {
              "root_coverage": {
                "$ref": "#/$defs/rootCoverageCertificate"
              },
              "tie": {
                "$ref": "#/$defs/tieCertificate"
              }
            }
          },
          "entry_cluster": {
            "$ref": "#/$defs/cluster"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_outcome": {
            "const": "numerically_unresolved"
          }
        }
      },
      "then": {
        "properties": {
          "certificates": {
            "properties": {
              "unresolved": {
                "$ref": "#/$defs/unresolvedCertificate"
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_outcome": {
            "enum": [
              "no_entry_proved",
              "right_censored_no_entry"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "certificates": {
            "properties": {
              "no_entry": {
                "$ref": "#/$defs/noEntryCertificate"
              },
              "root_coverage": {
                "$ref": "#/$defs/rootCoverageCertificate"
              }
            }
          },
          "entry_cluster": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_outcome": {
            "enum": [
              "right_censored_active_episode",
              "tie_cluster",
              "degenerate_spatial_minimum",
              "grazing_entry",
              "regular_first_entry"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "certificates": {
            "properties": {
              "closest": {
                "$ref": "#/$defs/closestCertificate"
              },
              "global_minimum": {
                "$ref": "#/$defs/globalCertificate"
              },
              "no_earlier_entry": {
                "$ref": "#/$defs/globalCertificate"
              },
              "outer_exit": {
                "$ref": "#/$defs/outerExitCertificate"
              },
              "root_coverage": {
                "$ref": "#/$defs/rootCoverageCertificate"
              }
            }
          },
          "entry_cluster": {
            "$ref": "#/$defs/cluster"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_outcome": {
            "const": "tie_cluster"
          }
        }
      },
      "then": {
        "properties": {
          "certificates": {
            "properties": {
              "tie": {
                "$ref": "#/$defs/tieCertificate"
              }
            }
          },
          "entry_cluster": {
            "properties": {
              "representation": {
                "enum": [
                  "finite",
                  "implicit"
                ]
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "primary_outcome": {
            "enum": [
              "degenerate_spatial_minimum",
              "grazing_entry",
              "regular_first_entry"
            ]
          }
        }
      },
      "then": {
        "properties": {
          "entry_cluster": {
            "properties": {
              "representation": {
                "const": "singleton"
              }
            }
          }
        }
      }
    }
  ],
  "properties": {
    "certificates": {
      "additionalProperties": false,
