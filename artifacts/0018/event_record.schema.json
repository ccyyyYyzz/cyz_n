        "status"
      ],
      "type": "object"
    },
    "cluster": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "representation": {
                "const": "singleton"
              }
            }
          },
          "then": {
            "properties": {
              "cardinality": {
                "const": 1
              },
              "implicit_set": {
                "type": "null"
              },
              "members": {
                "items": {
                  "$ref": "#/$defs/representative"
                },
                "maxItems": 1,
                "minItems": 1,
                "type": "array"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "representation": {
                "const": "finite"
              }
            }
          },
          "then": {
            "properties": {
              "cardinality": {
                "minimum": 2,
                "type": "integer"
              },
              "implicit_set": {
                "type": "null"
              },
              "members": {
                "items": {
                  "$ref": "#/$defs/representative"
                },
                "minItems": 2,
                "type": "array"
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "representation": {
                "const": "implicit"
              }
            }
          },
          "then": {
            "properties": {
              "cardinality": {
                "enum": [
                  "continuum",
                  "unknown"
                ]
              },
              "implicit_set": {
                "$ref": "#/$defs/implicitSet"
              },
              "members": {
                "maxItems": 0,
                "type": "array"
              }
            }
          }
        }
      ],
      "properties": {
        "cardinality": {
          "oneOf": [
            {
              "minimum": 1,
              "type": "integer"
            },
            {
              "enum": [
                "continuum",
                "unknown"
              ]
            }
          ]
        },
        "complete": {
          "type": "boolean"
        },
        "implicit_set": {
          "anyOf": [
