    "rank": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "certified"
              }
            }
          },
          "then": {
            "properties": {
              "exact_rank": {
                "maximum": 3,
                "minimum": 0,
                "type": "integer"
              },
              "possible_ranks": {
                "maxItems": 1,
                "minItems": 1
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "unresolved"
              }
            }
          },
          "then": {
            "properties": {
              "exact_rank": {
                "type": "null"
              },
              "possible_ranks": {
                "minItems": 2
              }
            }
          }
        }
      ],
      "properties": {
        "exact_rank": {
          "oneOf": [
            {
              "maximum": 3,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ]
        },
        "possible_ranks": {
          "items": {
            "maximum": 3,
            "minimum": 0,
            "type": "integer"
          },
          "maxItems": 4,
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "proof_kind": {
          "minLength": 1,
          "type": "string"
        },
        "status": {
          "enum": [
            "certified",
            "unresolved"
          ]
        }
      },
      "required": [
        "status",
        "exact_rank",
        "possible_ranks",
